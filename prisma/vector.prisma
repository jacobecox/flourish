generator client {
  provider      = "prisma-client"
  output        = "../lib/generated/prisma-vector"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("VECTOR_DATABASE_URL")
}

// ─────────────────────────────────────────────
// Embedding
// Stores text chunks + their vector embeddings
// sourceType: 'journal_entry' | 'recipe' | 'knowledge'
// sourceId: ID from flourish DB (null for knowledge base)
// userId: null for knowledge base entries
// ─────────────────────────────────────────────
model Embedding {
  id         String                   @id @default(cuid())
  sourceType String
  sourceId   String?
  userId     String?
  content    String
  embedding  Unsupported("vector(1024)")
  metadata   Json?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  @@index([userId])
  @@index([sourceType, sourceId])
}
