# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Random 32+ character string used to sign session cookies
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
# Main application database (users, recipes, journal entries)
DATABASE_URL=postgresql://user:password@localhost:5432/flourish

# Separate database with pgvector extension (AI embeddings)
VECTOR_DATABASE_URL=postgresql://user:password@localhost:5432/flourish_vector

# ─────────────────────────────────────────────
# FusionAuth
# ─────────────────────────────────────────────
FUSIONAUTH_URL=http://localhost:9011
# Application UUID from FusionAuth dashboard
FUSIONAUTH_CLIENT_ID=
# OAuth2 client secret from FusionAuth dashboard
FUSIONAUTH_CLIENT_SECRET=
# API key with login, registration, and user management permissions
FUSIONAUTH_API_KEY=
# UUID of the Google OIDC identity provider (only needed for Google OAuth)
FUSIONAUTH_GOOGLE_IDP_ID=

# ─────────────────────────────────────────────
# Email (Resend)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_...
# Must be a verified sender domain in your Resend account
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─────────────────────────────────────────────
# Storage (S3-compatible — Cloudflare R2 or AWS S3)
# ─────────────────────────────────────────────
# R2 endpoint: https://<account-id>.r2.cloudflarestorage.com
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=
# Public URL for uploaded files (R2 public bucket URL or CDN)
STORAGE_PUBLIC_URL=

# ─────────────────────────────────────────────
# AI / Embeddings
# ─────────────────────────────────────────────
# Anthropic Claude — used for the AI baking assistant
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI — used to generate text embeddings for RAG
VOYAGE_API_KEY=pa-...
